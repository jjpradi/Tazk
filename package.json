  "scripts": {
    "start": "vite",
    "build": "node --max-old-space-size=8192 ./node_modules/vite/bin/vite.js build",
    "build:strict": "VITE_STRICT_BUILD=true npm run build",
    "preview": "vite preview",
    "test": "vitest",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report tests/e2e/report",
    "deps:check": "node scripts/check-dependency-integrity.js",
    "smoke:regression": "node scripts/smoke-regression-checks.js",
    "ci:gate": "npm run deps:check && npm run smoke:regression && npm run build:strict",
    "lint": "eslint \"src/**/*.+(js|jsx)\"",
    "lint:fix": "eslint --fix \"src/**/*.+(js|jsx)\"",
    "format": "prettier --write \"src/**/*.+(js|jsx)\"",
    "precommit": "lint-staged",
    "postinstall": "node scripts/patch-react-draggable.js && node scripts/patch-react-peers.js"
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended",
      "plugin:react/recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2021,
      "sourceType": "module",
      "ecmaFeatures": {
        "jsx": true
      }
    },
    "env": {
      "browser": true,
      "es2021": true,
      "node": true
    },
    "settings": {
      "react": {
        "version": "detect"
      }
    }
  },
